{
  "name": "strictly-spending",
  "version": "0.1.0",
  "description": "A local-first household spending dashboard. Multi-bank CSV ingestion, rule-based categorization, recurring-charge detection, per-category budgets, and a rapid-triage Sort view — all in the browser. No server, no cloud, no account credentials.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:demo": "tsc -b && VITE_DEMO_ONLY=true vite build --mode demo --base /strictly-spending-demo/ --outDir dist-demo --emptyOutDir",
    "preview": "vite preview",
    "preview:demo": "vite preview --outDir dist-demo --base /strictly-spending-demo/",
    "deploy:demo": "npm run build:demo && DEST=${BARNESY_NEW:-../../projects/barnesy-new}/strictly-spending-demo && rm -rf \"$DEST\" && cp -r dist-demo \"$DEST\" && echo Deployed to $DEST",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "tauri": "tauri"
  },
  "keywords": [
    "budgeting",
    "personal-finance",
    "local-first",
    "indexeddb",
    "react",
    "typescript",
    "mui",
    "csv-import",
    "categorization"
  ],
  "license": "MIT",
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.11",
    "@mui/material": "^7.3.11",
    "@mui/x-charts": "^7.29.1",
    "@mui/x-data-grid": "^7.29.13",
    "@mui/x-date-pickers": "^7.29.4",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-http": "^2.5.9",
    "date-fns": "^4.3.0",
    "dexie": "^4.4.2",
    "dexie-react-hooks": "^4.4.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-resizable-panels": "^4.11.2",
    "react-router-dom": "^7.15.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^24.12.3",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~5.7",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.7"
  }
}
