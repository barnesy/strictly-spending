{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "fs:default",
    "fs:read-all",
    "fs:write-all",
    "dialog:default",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "http://localhost:11434/*"
        },
        {
          "url": "http://127.0.0.1:11434/*"
        }
      ]
    },
    {
      "identifier": "shell:allow-open",
      "allow": [
        {
          "url": "https://github.com/barnesy/strictly-spending/issues/new"
        }
      ]
    },
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-close",
    "playwright:default"
  ]
}
